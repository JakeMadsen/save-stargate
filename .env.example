NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
MONGO_URI=mongodb://127.0.0.1:27017/save-the-gate
SESSION_SECRET=change-me-before-production
OWNER_EMAIL=you@example.com

# Email delivery. Generic SMTP_* works, but ZeptoMail projects can use the ZEPTO_* names below.
MAIL_PROVIDER=zeptomail
SMTP_FROM="Save The Gate <noreply@savethegate.org>"
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true

# ZeptoMail SMTP
ZEPTO_SMTP_HOST=smtp.zeptomail.eu
ZEPTO_SMTP_PORT=587
ZEPTO_SMTP_USER=emailapikey
ZEPTO_SMTP_PASS=

# ZeptoMail API/template keys are optional; the current app sends via SMTP.
ZEPTO_API_BASE=https://zeptomail.zoho.eu
ZEPTO_API_KEY=
ZEPTO_ACCOUNT_KEY=
ZEPTO_TEMPLATE_VERIFY_KEY=
ZEPTO_TEMPLATE_RESET_KEY=

PETITION_SYNC_INTERVAL_MINUTES=60
